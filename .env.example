# Folio environment

# Optional: WalletConnect Cloud project id
# Enables WalletConnect QR for Rainbow, Trust, Ledger, OKX, and more.
# MetaMask + Coinbase Wallet work without this.
# https://cloud.walletconnect.com/
NEXT_PUBLIC_WC_PROJECT_ID=

# Optional: public app URL for wallet connection metadata
NEXT_PUBLIC_APP_URL=

# FolioIP ERC-721 deployed on Base / Base Sepolia
NEXT_PUBLIC_FOLIO_IP_ADDRESS=

# Auth + encrypted customer data (required for /login and /account)
# Generate with: openssl rand -hex 32
CUSTOMER_DATA_KEY=
SESSION_SECRET=
# Optional separate secret for email lookup HMAC (defaults to CUSTOMER_DATA_KEY)
EMAIL_INDEX_SECRET=

# Password recovery (optional email delivery via Resend)
# Without RESEND_API_KEY, reset links are written to .data/password-reset-outbox.json
# https://resend.com/
RESEND_API_KEY=
PASSWORD_RESET_FROM_EMAIL=
# Set true to include resetUrl in API responses (defaults on in development)
PASSWORD_RESET_REVEAL_URL=

# Document vault encryption (AES-256-GCM). Falls back to CUSTOMER_DATA_KEY if unset.
# Generate with: openssl rand -hex 32
DOCUMENT_ENCRYPTION_KEY=
