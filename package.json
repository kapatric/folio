{
  "name": "folio",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "setup": "node scripts/ensure-env.js",
    "predev": "node scripts/ensure-env.js && node scripts/ensure-wallet-sdks.js",
    "prebuild": "node scripts/ensure-env.js && node scripts/ensure-wallet-sdks.js",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed:account": "node scripts/seed-account.mjs",
    "postinstall": "node scripts/ensure-lightningcss.js && node scripts/ensure-wallet-sdks.js && node scripts/ensure-env.js",
    "clean": "rm -rf .next node_modules",
    "reinstall": "npm run clean && npm install"
  },
  "dependencies": {
    "@coinbase/wallet-sdk": "^4.3.7",
    "@metamask/connect-evm": "^2.1.1",
    "@tanstack/react-query": "^5.101.2",
    "@wagmi/connectors": "^8.0.23",
    "@walletconnect/ethereum-provider": "^2.23.10",
    "next": "^16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "viem": "^2.55.2",
    "wagmi": "^3.7.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "lightningcss": "1.32.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "lightningcss-darwin-arm64": "1.32.0",
    "lightningcss-darwin-x64": "1.32.0",
    "lightningcss-linux-arm64-gnu": "1.32.0",
    "lightningcss-linux-x64-gnu": "1.32.0",
    "lightningcss-win32-x64-msvc": "1.32.0"
  }
}
